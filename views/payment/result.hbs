<style>
  .result-wrap { max-width: 480px; margin: 0 auto; text-align: center; padding-top: 20px; }
  .result-icon { font-size: 72px; margin-bottom: 16px; }
  .result-title { font-size: 24px; font-weight: 700; margin-bottom: 6px; }
  .result-sub { color: var(--muted); font-size: 14px; margin-bottom: 28px; }

  .info-table { text-align: left; width: 100%; margin-bottom: 24px; }
  .info-row { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--border); font-size: 14px; }
  .info-row:last-child { border-bottom: none; }
  .info-label { color: var(--muted); }
  .info-val { font-weight: 600; }
  .info-val.amount { color: var(--green); font-size: 18px; font-weight: 700; }

  .result-actions { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }
</style>

<div class="result-wrap">
  {{#if success}}
    <div class="result-icon">✅</div>
    <div class="result-title" style="color:var(--green)">Payment Successful!</div>
    <div class="result-sub">Your order has been confirmed and sent to the kitchen.</div>

    <div class="card">
      <div class="info-table">
        <div class="info-row">
          <span class="info-label">Order ID</span>
          <span class="info-val">#{{payment.order_id}}</span>
        </div>
        <div class="info-row">
          <span class="info-label">Transaction ID</span>
          <span class="info-val" style="font-size:12px;word-break:break-all">{{payment.transaction_id}}</span>
        </div>
        <div class="info-row">
          <span class="info-label">Method</span>
          <span class="info-val" style="text-transform:capitalize">{{payment.method}}</span>
        </div>
        <div class="info-row">
          <span class="info-label">Amount</span>
          <span class="info-val amount">${{payment.amount}}</span>
        </div>
        <div class="info-row">
          <span class="info-label">Date</span>
          <span class="info-val">{{formatDate payment.paid_at}}</span>
        </div>
      </div>
    </div>

    <div class="result-actions mt-16">
      <a href="/order-tracking/{{payment.order_id}}" class="btn btn-primary">Track Order →</a>
      <a href="/" class="btn btn-ghost">Back to Menu</a>
      <a href="/notification?userId=1" class="btn btn-ghost">🔔 Notifications</a>
    </div>

  {{else if alreadyPaid}}
    <div class="result-icon">ℹ️</div>
    <div class="result-title">Already Paid</div>
    <div class="result-sub">This order has already been paid.</div>
    <div class="result-actions">
      <a href="/" class="btn btn-primary">Back to Menu</a>
    </div>

  {{else}}
    <div class="result-icon">❌</div>
    <div class="result-title" style="color:var(--red)">Payment Failed</div>
    <div class="result-sub">{{message}}</div>
    <div class="result-actions">
      <button class="btn btn-red" onclick="history.back()">Try Again</button>
      <a href="/" class="btn btn-ghost">Back to Menu</a>
    </div>
  {{/if}}
</div>

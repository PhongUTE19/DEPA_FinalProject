<style>
  .history-header { margin-bottom: 24px; }
  .history-header h1 { font-size: 22px; }
  .history-header p { color: var(--muted); font-size: 14px; margin-top: 2px; }

  .payment-list { display: flex; flex-direction: column; gap: 12px; max-width: 640px; }
  .payment-item {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 14px 18px;
    display: flex; align-items: center; justify-content: space-between; gap: 12px;
  }
  .payment-item:hover { border-color: var(--accent); }
  .payment-left { display: flex; align-items: center; gap: 14px; }
  .payment-emoji { font-size: 28px; }
  .payment-id { font-weight: 700; font-size: 14px; }
  .payment-meta { font-size: 12px; color: var(--muted); }
  .payment-txn { font-size: 11px; color: var(--muted); font-family: monospace; }
  .payment-right { text-align: right; }
  .payment-amount { font-size: 17px; font-weight: 700; color: var(--green); }
  .payment-status { font-size: 12px; color: var(--green); background: var(--green-light); padding: 2px 8px; border-radius: 20px; font-weight: 600; }

  .empty-state { text-align: center; padding: 64px 0; color: var(--muted); }
  .empty-state .big { font-size: 48px; display: block; margin-bottom: 12px; }
</style>

<div class="history-header">
  <h1>💳 Payment History</h1>
  <p>All your transactions</p>
</div>

{{#if (isEmpty payments)}}
  <div class="empty-state">
    <span class="big">🧾</span>
    <div>No payments yet.</div>
    <a href="/" class="btn btn-primary" style="margin-top:16px;">Order Something</a>
  </div>
{{else}}
  <div class="payment-list">
    {{#each payments}}
    <div class="payment-item">
      <div class="payment-left">
        <span class="payment-emoji">
          {{#if (eq method "cash")}}💵{{else if (eq method "bank")}}🏦{{else if (eq method "momo")}}📱{{else}}💳{{/if}}
        </span>
        <div>
          <div class="payment-id">Order #{{order_id}}</div>
          <div class="payment-meta">{{formatDate paid_at}} &bull; {{method}}</div>
          <div class="payment-txn">{{transaction_id}}</div>
        </div>
      </div>
      <div class="payment-right">
        <div class="payment-amount">${{amount}}</div>
        <div class="payment-status">{{status}}</div>
      </div>
    </div>
    {{/each}}
  </div>
{{/if}}

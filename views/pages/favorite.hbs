<style>
  body { background: #0f0f0f; color: #f1f1f1; font-family: 'Segoe UI', sans-serif; }
  .fav-hero { text-align: center; padding: 48px 20px 24px; }
  .fav-hero h1 { font-size: 2.2rem; font-weight: 700; color: #fff; }
  .fav-hero p { color: #888; }
  .menu-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px; padding: 20px 40px 60px; max-width: 1200px; margin: 0 auto; }
  .food-card { background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 16px; overflow: hidden; }
  .food-card-img { width: 100%; height: 150px; background: #2a2a2a; display: flex; align-items: center; justify-content: center; font-size: 3.5rem; }
  .food-card-body { padding: 14px; }
  .food-card-type { font-size: 0.75rem; color: #e85d24; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 4px; }
  .food-card-name { font-size: 1rem; font-weight: 600; color: #fff; margin-bottom: 8px; }
  .food-card-footer { display: flex; justify-content: space-between; align-items: center; }
  .food-card-price { color: #e85d24; font-weight: 700; }
  .btn-unfav { background: transparent; border: 1px solid #e85d24; color: #e85d24; border-radius: 8px; padding: 5px 12px; font-size: 0.8rem; cursor: pointer; margin-top: 8px; width: 100%; }
  .btn-unfav:hover { background: #e85d24; color: #fff; }
  .empty { text-align: center; color: #555; padding: 60px; font-size: 1.1rem; }
</style>

<div class="fav-hero">
  <h1>❤️ Yêu thích</h1>
  <p>Danh sách món bạn đã lưu</p>
</div>

{{#if foods.length}}
<div class="menu-grid">
  {{#each foods}}
  <div class="food-card">
    <div class="food-card-img">{{typeEmoji type}}</div>
    <div class="food-card-body">
      <div class="food-card-type">{{type}}</div>
      <div class="food-card-name">{{name}}</div>
      <div class="food-card-footer">
       <span class="food-card-price">{{base_price}}k</span>
      </div>
      <button class="btn-unfav" onclick="removeFav({{id}}, this)">🗑️ Xoá khỏi yêu thích</button>
    </div>
  </div>
  {{/each}}
</div>
{{else}}
<p class="empty">Chưa có món yêu thích nào 😕 <a href="/menu" style="color:#e85d24">Khám phá menu</a></p>
{{/if}}

<script>
  async function removeFav(foodId, btn) {
    const res = await fetch('/favorite/' + foodId, { method: 'DELETE' });
    const data = await res.json();
    if (data.success) btn.closest('.food-card').remove();
  }
</script>
{{#fillSection "css"}}
<style>
  .notif-page-header {
    background: linear-gradient(135deg, #ff6b35, #f7931e);
    border-radius: 16px;
    padding: 24px 32px;
    color: white;
    margin-bottom: 28px;
  }

  .notif-page-header h2 {
    font-weight: 800;
    margin: 0;
    font-size: 1.8rem;
  }

  .notif-item {
    border-radius: 12px;
    border: 1px solid #e9ecef;
    padding: 16px 20px;
    transition: all 0.2s;
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .notif-item:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
    transform: translateY(-1px);
    color: inherit;
  }

  .notif-item.unread {
    background: #fff8f0;
    border-left: 4px solid #ff6b35;
  }

  .notif-icon {
    font-size: 1.8rem;
  }

  .notif-time {
    font-size: 0.78rem;
    color: #adb5bd;
  }

  .badge-event {
    font-size: 0.72rem;
    border-radius: 8px;
    padding: 3px 10px;
    font-weight: 600;
  }

  .empty-state {
    text-align: center;
    padding: 60px 0;
    color: #adb5bd;
  }

  .empty-state i {
    font-size: 4rem;
  }

  .unread-badge {
    background: #ff6b35;
    color: white;
    border-radius: 20px;
    padding: 4px 14px;
    font-size: 0.85rem;
    font-weight: 600;
  }

  .btn-read-all {
    background: white;
    border: 1px solid rgba(255, 255, 255, 0.6);
    color: #ff6b35;
    border-radius: 8px;
    padding: 6px 18px;
    font-weight: 600;
    font-size: 0.88rem;
    transition: all 0.2s;
  }

  .btn-read-all:hover {
    background: rgba(255, 255, 255, 0.9);
  }
</style>
{{/fillSection}}

<div class="col-12">
  <div class="container py-4" style="max-width: 800px;">
    <div class="notif-page-header d-flex justify-content-between align-items-center">
      <div>
        <h2><i class="bi bi-bell-fill me-2"></i>Thông báo</h2>
        <p class="mb-0 opacity-75">
          {{#if unread}}
          <span class="unread-badge me-2">{{unread}} chưa đọc</span>
          {{else}}
          Tất cả đã đọc
          {{/if}}
        </p>
      </div>
      {{#if unread}}
      <button id="btnReadAll" class="btn-read-all">
        <i class="bi bi-check2-all me-1"></i>Đọc tất cả
      </button>
      {{/if}}
    </div>

    {{#if (isEmpty notifications)}}
    <div class="empty-state">
      <i class="bi bi-bell-slash"></i>
      <p class="mt-3 fs-5">Chưa có thông báo nào</p>
    </div>
    {{else}}
    <div class="d-flex flex-column gap-3">
      {{#each notifications}}
      <a href="/notification/{{id}}" class="notif-item {{#unless isRead}}unread{{/unless}}">
        <div class="d-flex align-items-start gap-3">
          <span class="notif-icon">
            {{#if (eq event "ORDER_CREATED")}}📦
            {{else if (eq event "ORDER_CONFIRMED")}}✅
            {{else if (eq event "ORDER_PREPARING")}}🍳
            {{else if (eq event "ORDER_READY")}}🔔
            {{else if (eq event "ORDER_COMPLETED")}}🎉
            {{else if (eq event "ORDER_CANCELLED")}}🚫
            {{else if (eq event "ORDER_PAID")}}💰
            {{else if (eq event "PAYMENT_FAILED")}}❌
            {{else}}📢{{/if}}
          </span>
          <div class="flex-grow-1">
            <div class="d-flex align-items-center gap-2 mb-1">
              <span class="fw-bold">{{message}}</span>
              {{#unless isRead}}
              <span class="badge badge-event bg-danger text-white">MỚI</span>
              {{/unless}}
            </div>
            <div class="d-flex gap-2 align-items-center flex-wrap">
              <span class="notif-time">
                <i class="bi bi-clock me-1"></i>{{formatDate createdAt}}
              </span>
              {{#if orderId}}
              <span class="badge badge-event bg-light text-dark">
                Đơn #{{orderId}}
              </span>
              {{/if}}
              <span class="badge badge-event bg-secondary-subtle text-secondary">
                {{event}}
              </span>
            </div>
          </div>
          <i class="bi bi-chevron-right text-muted"></i>
        </div>
      </a>
      {{/each}}
    </div>
    {{/if}}
  </div>
</div>

{{#fillSection "js"}}
<script>
  document.getElementById('btnReadAll')?.addEventListener('click', async () => {
    await fetch('/notification/read-all', { method: 'PATCH', headers: { 'Content-Type': 'application/json' } });
    location.reload();
  });
</script>
{{/fillSection}}
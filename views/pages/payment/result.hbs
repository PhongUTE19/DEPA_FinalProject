{{#fillSection "css"}}
<style>
    .result-card {
        border-radius: 20px;
        padding: 48px 40px;
        text-align: center;
        max-width: 520px;
        margin: 0 auto;
    }

    .result-icon {
        font-size: 5rem;
        margin-bottom: 16px;
    }

    .result-success {
        background: #f0fff4;
        border: 2px solid #b7ebce;
    }

    .result-fail {
        background: #fff5f5;
        border: 2px solid #ffc9c9;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid #e9ecef;
        font-size: 0.92rem;
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-row .label {
        color: #6c757d;
    }

    .info-row .value {
        font-weight: 600;
    }

    .amount-big {
        font-size: 2rem;
        font-weight: 700;
        color: #ff6b35;
    }

    .btn-actions {
        display: flex;
        gap: 10px;
        justify-content: center;
        flex-wrap: wrap;
    }
</style>
{{/fillSection}}

<div class="col-12">
    <div class="container py-5">
        {{#if success}}
        <div class="result-card result-success">
            <div class="result-icon">✅</div>
            <h2 class="fw-bold text-success mb-1">Thanh toán thành công!</h2>
            <p class="text-muted mb-4">Đơn hàng của bạn đã được xác nhận</p>

            <div class="text-start mb-4">
                <div class="info-row">
                    <span class="label">Mã đơn hàng</span>
                    <span class="value">#{{payment.orderId}}</span>
                </div>
                <div class="info-row">
                    <span class="label">Mã giao dịch</span>
                    <span class="value" style="font-size:0.85rem">{{payment.transactionId}}</span>
                </div>
                <div class="info-row">
                    <span class="label">Phương thức</span>
                    <span class="value text-capitalize">
                        {{#if (eq payment.method "cash")}}💵 Tiền mặt
                        {{else if (eq payment.method "bank")}}🏦 Ngân hàng
                        {{else if (eq payment.method "momo")}}📱 MoMo
                        {{else}}{{payment.method}}{{/if}}
                    </span>
                </div>
                <div class="info-row">
                    <span class="label">Số tiền</span>
                    <span class="amount-big">{{formatCurrency payment.amount}}</span>
                </div>
                <div class="info-row">
                    <span class="label">Thời gian</span>
                    <span class="value">{{formatDate payment.paidAt}}</span>
                </div>
            </div>

            <div class="btn-actions">
                <a href="/" class="btn btn-success rounded-pill px-4">
                    <i class="bi bi-house-fill me-1"></i>Về trang chủ
                </a>
                <a href="/notification" class="btn btn-outline-secondary rounded-pill px-4">
                    <i class="bi bi-bell me-1"></i>Thông báo
                </a>
                <a href="/payment/history" class="btn btn-outline-primary rounded-pill px-4">
                    <i class="bi bi-clock-history me-1"></i>Lịch sử
                </a>
            </div>
        </div>

        {{else if alreadyPaid}}
        <div class="result-card result-success">
            <div class="result-icon">ℹ️</div>
            <h2 class="fw-bold mb-1">Đã thanh toán</h2>
            <p class="text-muted">Đơn hàng này đã được thanh toán trước đó</p>
            <a href="/" class="btn btn-primary rounded-pill px-4 mt-3">Về trang chủ</a>
        </div>

        {{else}}
        <div class="result-card result-fail">
            <div class="result-icon">❌</div>
            <h2 class="fw-bold text-danger mb-1">Thanh toán thất bại</h2>
            <p class="text-muted mb-4">{{message}}</p>
            <button onclick="history.back()" class="btn btn-danger rounded-pill px-4">
                <i class="bi bi-arrow-left me-1"></i>Thử lại
            </button>
        </div>
        {{/if}}
    </div>
</div>
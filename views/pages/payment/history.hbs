{{#fillSection "css"}}
<style>
    .payment-item {
        border-radius: 12px;
        border: 1px solid #e9ecef;
        padding: 16px 20px;
        transition: box-shadow 0.2s;
    }
    .payment-item:hover { box-shadow: 0 2px 12px rgba(0,0,0,0.08); }
    .badge-method {
        background: #fff3e6;
        color: #e8590c;
        border-radius: 8px;
        padding: 4px 10px;
        font-size: 0.8rem;
        font-weight: 600;
    }
    .empty-state { text-align: center; padding: 60px 0; color: #adb5bd; }
    .empty-state i { font-size: 4rem; }
</style>
{{/fillSection}}

<div class="col-12">
    <div class="container py-5" style="max-width: 720px;">
        <h2 class="fw-bold mb-1">💳 Lịch sử thanh toán</h2>
        <p class="text-muted mb-4">Tất cả giao dịch của bạn</p>

        {{#if (isEmpty payments)}}
        <div class="empty-state">
            <i class="bi bi-receipt"></i>
            <p class="mt-3 fs-5">Chưa có giao dịch nào</p>
        </div>
        {{else}}
        <div class="d-flex flex-column gap-3">
            {{#each payments}}
            <div class="payment-item d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center gap-3">
                    <span style="font-size:1.8rem">
                        {{#if (eq method "cash")}}💵
                        {{else if (eq method "bank")}}🏦
                        {{else if (eq method "momo")}}📱
                        {{else}}💳{{/if}}
                    </span>
                    <div>
                        <div class="fw-semibold">Đơn hàng #{{order_id}}</div>
                        <div class="text-muted" style="font-size:0.82rem">
                            {{formatDate paid_at}} &bull;
                            <span class="badge-method">{{method}}</span>
                        </div>
                        <div class="text-muted" style="font-size:0.75rem">GD: {{transaction_id}}</div>
                    </div>
                </div>
                <div class="text-end">
                    <div class="fw-bold text-success fs-5">{{formatCurrency amount}}</div>
                    <span class="badge bg-success-subtle text-success">{{status}}</span>
                </div>
            </div>
            {{/each}}
        </div>
        {{/if}}
    </div>
</div>

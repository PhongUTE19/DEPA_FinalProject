{{#fillSection "css"}}
<style>
    .payment-item {
        border-radius: 12px;
        border: 1px solid #e9ecef;
        padding: 16px 20px;
        transition: all 0.2s;
    }

    .payment-item:hover {
        box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
        transform: translateY(-1px);
    }

    .badge-method {
        background: #fff3e6;
        color: #e8590c;
        border-radius: 8px;
        padding: 4px 10px;
        font-size: 0.8rem;
        font-weight: 600;
    }

    .empty-state {
        text-align: center;
        padding: 60px 0;
        color: #adb5bd;
    }

    .empty-state i {
        font-size: 4rem;
    }

    .history-header {
        background: linear-gradient(135deg, #ff6b35, #f7931e);
        border-radius: 16px;
        padding: 24px 32px;
        color: white;
        margin-bottom: 28px;
    }

    .history-header h2 {
        font-weight: 800;
        margin: 0;
        font-size: 1.6rem;
    }

    .status-badge {
        border-radius: 20px;
        padding: 4px 14px;
        font-size: 0.78rem;
        font-weight: 600;
    }

    .status-success {
        background: #d3f9d8;
        color: #2b8a3e;
    }

    .status-failed {
        background: #ffe3e3;
        color: #c92a2a;
    }

    .status-pending {
        background: #fff3bf;
        color: #e67700;
    }
</style>
{{/fillSection}}

<div class="col-12">
    <div class="container py-5" style="max-width: 720px;">
        <div class="history-header">
            <h2><i class="bi bi-clock-history me-2"></i>Lịch sử thanh toán</h2>
            <p class="mb-0 opacity-75">Tất cả giao dịch của bạn</p>
        </div>

        {{#if (isEmpty payments)}}
        <div class="empty-state">
            <i class="bi bi-receipt"></i>
            <p class="mt-3 fs-5">Chưa có giao dịch nào</p>
            <a href="/order" class="btn btn-outline-primary mt-2">Xem đơn hàng</a>
        </div>
        {{else}}
        <div class="d-flex flex-column gap-3">
            {{#each payments}}
            <div class="payment-item d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center gap-3">
                    <span style="font-size:1.8rem">
                        {{#if (eq method "cash")}}💵
                        {{else if (eq method "bank")}}🏦
                        {{else if (eq method "momo")}}📱
                        {{else}}💳{{/if}}
                    </span>
                    <div>
                        <div class="fw-semibold">Đơn hàng #{{orderId}}</div>
                        <div class="text-muted" style="font-size:0.82rem">
                            {{formatDate paidAt}} &bull;
                            <span class="badge-method">
                                {{#if (eq method "cash")}}Tiền mặt
                                {{else if (eq method "bank")}}Ngân hàng
                                {{else if (eq method "momo")}}MoMo
                                {{else}}{{method}}{{/if}}
                            </span>
                        </div>
                        {{#if transactionId}}
                        <div class="text-muted" style="font-size:0.75rem">GD: {{transactionId}}</div>
                        {{/if}}
                    </div>
                </div>
                <div class="text-end">
                    <div class="fw-bold fs-5" style="color: #ff6b35;">{{formatCurrency amount}}</div>
                    <span class="status-badge
                        {{#if (eq status 'SUCCESS')}}status-success
                        {{else if (eq status 'FAILED')}}status-failed
                        {{else}}status-pending{{/if}}">
                        {{#if (eq status "SUCCESS")}}Thành công
                        {{else if (eq status "FAILED")}}Thất bại
                        {{else if (eq status "PENDING")}}Đang xử lý
                        {{else}}{{status}}{{/if}}
                    </span>
                </div>
            </div>
            {{/each}}
        </div>
        {{/if}}
    </div>
</div>
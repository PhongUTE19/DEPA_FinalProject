{{#fillSection "css"}}
<style>
    .payment-card {
        border: 2px solid #e9ecef;
        border-radius: 16px;
        padding: 20px;
        cursor: pointer;
        transition: all 0.2s ease;
    }

    .payment-card:hover {
        border-color: #ff6b35;
        background: #fff5f0;
        transform: translateY(-2px);
        box-shadow: 0 4px 16px rgba(255, 107, 53, 0.15);
    }

    .payment-card.selected {
        border-color: #ff6b35;
        background: #fff5f0;
    }

    .payment-card .method-icon {
        font-size: 2.5rem;
    }

    .payment-card input[type="radio"] {
        display: none;
    }

    .btn-pay {
        background: #ff6b35;
        border: none;
        border-radius: 12px;
        padding: 14px 40px;
        font-size: 1.1rem;
        font-weight: 600;
        color: white;
        width: 100%;
        transition: background 0.2s;
    }

    .btn-pay:hover {
        background: #e85a24;
    }

    .order-summary {
        background: #f8f9fa;
        border-radius: 16px;
        padding: 24px;
    }

    .total-amount {
        font-size: 1.8rem;
        font-weight: 700;
        color: #ff6b35;
    }

    .coupon-section {
        background: #fff8f4;
        border: 2px dashed #ffd4c0;
        border-radius: 14px;
        padding: 20px 24px;
    }

    .coupon-input-group {
        display: flex;
        gap: 10px;
    }

    .coupon-input-group input {
        flex: 1;
        border-radius: 10px;
        border: 1px solid #ddd;
        padding: 10px 16px;
        font-weight: 600;
        letter-spacing: 1px;
        text-transform: uppercase;
    }

    .coupon-input-group input:focus {
        border-color: #ff6b35;
        outline: none;
        box-shadow: 0 0 0 3px rgba(255, 107, 53, 0.15);
    }

    .btn-coupon {
        background: #ff6b35;
        color: white;
        border: none;
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 600;
        white-space: nowrap;
        transition: background 0.2s;
    }

    .btn-coupon:hover {
        background: #e85a24;
    }

    .coupon-result {
        margin-top: 12px;
        padding: 10px 16px;
        border-radius: 10px;
        font-size: 0.9rem;
        display: none;
    }

    .coupon-result.success {
        background: #d3f9d8;
        color: #2b8a3e;
        display: block;
    }

    .coupon-result.error {
        background: #ffe3e3;
        color: #c92a2a;
        display: block;
    }

    .discount-row {
        color: #2b8a3e;
        font-weight: 600;
        display: none;
    }

    .discount-row.show {
        display: flex;
    }

    .page-header {
        background: linear-gradient(135deg, #ff6b35, #f7931e);
        border-radius: 16px;
        padding: 24px 32px;
        color: white;
        margin-bottom: 28px;
    }

    .page-header h2 {
        font-weight: 800;
        margin: 0;
        font-size: 1.6rem;
    }

    .coupon-card {
        background: white;
        border: 2px solid #e9ecef;
        border-radius: 10px;
        padding: 12px;
        cursor: pointer;
        transition: all 0.2s ease;
        text-align: center;
        font-size: 0.85rem;
    }

    .coupon-card:hover {
        border-color: #ff6b35;
        background: #fff5f0;
        transform: translateY(-2px);
        box-shadow: 0 2px 8px rgba(255, 107, 53, 0.15);
    }

    .coupon-card:active {
        border-color: #ff6b35;
        background: #ffe8dc;
    }
</style>
{{/fillSection}}

<div class="col-12">
    <div class="container py-5" style="max-width: 680px;">
        <div class="page-header">
            <h2>🧾 Thanh toán đơn hàng</h2>
            <p class="mb-0 opacity-75">Mã đơn: <strong>#{{orderId}}</strong></p>
        </div>

        <form action="/payment" method="POST" id="paymentForm">
            <input type="hidden" name="orderId" value="{{orderId}}">
            <input type="hidden" name="userId" value="{{userId}}">
            <input type="hidden" name="totalAmount" id="totalAmountInput" value="{{totalAmount}}">
            <input type="hidden" id="totalAmountData" value="{{totalAmount}}">
            <input type="hidden" name="couponCode" id="couponCodeInput" value="">

            {{!-- Order Summary --}}
            <div class="order-summary mb-4">
                <h5 class="fw-semibold mb-3">Tóm tắt đơn hàng</h5>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Mã đơn hàng</span>
                    <span class="fw-medium">#{{orderId}}</span>
                </div>

                {{!-- Danh sách món trong đơn --}}
                {{#if orderItems}}
                <div class="mb-3" style="border:1px solid #eee; border-radius:10px; padding:12px;">
                    <div class="fw-semibold mb-2" style="font-size:0.9rem;"><i class="bi bi-bag-check me-1"></i>Các món
                        đã đặt</div>
                    {{#each orderItems}}
                    <div class="d-flex justify-content-between align-items-center py-1"
                        style="font-size:0.88rem; border-bottom:1px solid #f5f5f5;">
                        <div>
                            <span class="fw-medium">{{name}} × {{quantity}}</span>
                            {{#if toppings.length}}
                            <div style="font-size:0.75rem; color:#888;">{{#each toppings}}{{this}}{{#unless @last}},
                                {{/unless}}{{/each}}</div>
                            {{/if}}
                        </div>
                        <span class="fw-semibold" style="color:#ff6b35;">{{formatNumber subtotal}}đ</span>
                    </div>
                    {{/each}}
                </div>
                {{/if}}

                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted">Tạm tính</span>
                    <span class="fw-medium" id="subtotalDisplay">{{formatCurrency totalAmount}}</span>
                </div>
                <div class="d-flex justify-content-between mb-2 discount-row" id="discountRow">
                    <span><i class="bi bi-tag-fill me-1"></i>Giảm giá</span>
                    <span id="discountDisplay">-0₫</span>
                </div>
                <hr>
                <div class="d-flex justify-content-between align-items-center">
                    <span class="fw-semibold">Tổng thanh toán</span>
                    <span class="total-amount" id="displayAmount">{{formatCurrency totalAmount}}</span>
                </div>
            </div>

            {{!-- Coupon Section --}}
            <div class="coupon-section mb-4">
                <h6 class="fw-semibold mb-2"><i class="bi bi-ticket-perforated me-1"></i>Mã giảm giá</h6>

                {{#if availableCoupons.length}}
                <div style="margin-bottom:12px;">
                    <div class="text-muted" style="font-size:0.9rem; margin-bottom:8px;">Chọn mã giảm giá khả dụng:
                    </div>
                    <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(140px, 1fr)); gap:8px;">
                        {{#each availableCoupons}}
                        <button type="button" class="coupon-card"
                            onclick="applyCouponQuick('{{code}}', {{discountAmount}}, this)">
                            <div style="font-weight:600; color:#ff6b35; font-size:0.9rem;">{{code}}</div>
                            <div style="font-size:0.75rem; color:#666;">Giảm {{formatNumber discountAmount}}đ</div>
                        </button>
                        {{/each}}
                    </div>
                </div>
                {{/if}}

                <div style="margin-top:12px; padding-top:12px; border-top:1px solid #eee;">
                    <div class="text-muted" style="font-size:0.9rem; margin-bottom:8px;">Hoặc nhập mã khác:</div>
                    <div class="coupon-input-group">
                        <input type="text" id="couponInput" placeholder="Nhập mã giảm giá...">
                        <button type="button" class="btn-coupon" id="btnApplyCoupon">
                            Áp dụng
                        </button>
                    </div>
                </div>

                <div class="coupon-result" id="couponResult"></div>
            </div>

            {{!-- Payment Methods --}}
            <h5 class="fw-semibold mb-3">Chọn phương thức thanh toán</h5>
            <div class="row g-3 mb-4">
                {{#each methods}}
                <div class="col-12 col-sm-4">
                    <label class="payment-card d-flex flex-column align-items-center gap-2 w-100"
                        onclick="selectMethod(this)" data-method="{{this}}">
                        <input type="radio" name="paymentMethod" value="{{this}}" required>
                        <span class="method-icon">
                            {{#if (eq this "cash")}}💵
                            {{else if (eq this "bank")}}🏦
                            {{else if (eq this "momo")}}📱
                            {{else}}💳{{/if}}
                        </span>
                        <span class="fw-semibold text-capitalize">
                            {{#if (eq this "cash")}}Tiền mặt
                            {{else if (eq this "bank")}}Ngân hàng
                            {{else if (eq this "momo")}}MoMo
                            {{else}}{{this}}{{/if}}
                        </span>
                        <small class="text-muted text-center">
                            {{#if (eq this "cash")}}Thanh toán khi nhận hàng
                            {{else if (eq this "bank")}}Chuyển khoản ngân hàng
                            {{else if (eq this "momo")}}Ví điện tử MoMo
                            {{/if}}
                        </small>
                    </label>
                </div>
                {{/each}}
            </div>

            <button type="submit" class="btn-pay">
                <i class="bi bi-lock-fill me-2"></i>Xác nhận thanh toán
            </button>
        </form>
    </div>
</div>

{{#fillSection "js"}}
<script>
    const fmt = v => new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(v);
    let originalAmount = parseInt(document.getElementById('totalAmountData').value) || 0;
    let discountAmount = 0;

    function selectMethod(el) {
        document.querySelectorAll('.payment-card').forEach(c => c.classList.remove('selected'));
        el.classList.add('selected');
        el.querySelector('input[type="radio"]').checked = true;
    }

    function updateDisplay() {
        const finalAmount = originalAmount - discountAmount;
        document.getElementById('subtotalDisplay').textContent = fmt(originalAmount);
        document.getElementById('displayAmount').textContent = fmt(finalAmount);
        document.getElementById('totalAmountInput').value = finalAmount;
    }

    async function applyCouponQuick(code, discount, btn) {
        const resultEl = document.getElementById('couponResult');
        try {
            // Verify coupon server-side to ensure it's still valid
            const res = await fetch('/coupon/apply', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ code, orderAmount: originalAmount }),
            });
            const data = await res.json();

            if (data.success) {
                discountAmount = data.discount;
                document.getElementById('couponCodeInput').value = code;
                document.getElementById('discountRow').classList.add('show');
                document.getElementById('discountDisplay').textContent = '-' + fmt(data.discount) + 'đ';
                document.getElementById('couponInput').value = '';
                resultEl.className = 'coupon-result success';
                resultEl.innerHTML = '<i class="bi bi-check-circle me-1"></i>Đã áp dụng mã <strong>' + code.toUpperCase() + '</strong>: giảm ' + fmt(data.discount) + 'đ';
                updateDisplay();
                // Highlight the selected coupon card
                document.querySelectorAll('.coupon-card').forEach(c => c.style.opacity = '0.6');
                if (btn) btn.style.opacity = '1';
            } else {
                resultEl.className = 'coupon-result error';
                resultEl.innerHTML = '<i class="bi bi-x-circle me-1"></i>' + (data.message || 'Không thể áp dụng mã giảm giá');
            }
        } catch (err) {
            console.error('Error applying coupon:', err);
            resultEl.className = 'coupon-result error';
            resultEl.innerHTML = '<i class="bi bi-x-circle me-1"></i>Lỗi: ' + err.message;
        }
    }

    document.getElementById('btnApplyCoupon')?.addEventListener('click', async () => {
        const code = document.getElementById('couponInput').value.trim();
        const resultEl = document.getElementById('couponResult');
        if (!code) {
            resultEl.className = 'coupon-result error';
            resultEl.textContent = 'Vui lòng nhập mã giảm giá';
            return;
        }

        try {
            const res = await fetch('/coupon/apply', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ code, orderAmount: originalAmount }),
            });
            const data = await res.json();

            if (data.success) {
                discountAmount = data.discount;
                document.getElementById('couponCodeInput').value = code;
                document.getElementById('discountRow').classList.add('show');
                document.getElementById('discountDisplay').textContent = '-' + fmt(data.discount);
                resultEl.className = 'coupon-result success';
                resultEl.innerHTML = '<i class="bi bi-check-circle me-1"></i>Đã áp dụng mã <strong>' + code.toUpperCase() + '</strong>: giảm ' + fmt(data.discount);
                updateDisplay();
            } else {
                resultEl.className = 'coupon-result error';
                resultEl.innerHTML = '<i class="bi bi-x-circle me-1"></i>' + data.message;
            }
        } catch {
            resultEl.className = 'coupon-result error';
            resultEl.textContent = 'Lỗi kết nối. Vui lòng thử lại.';
        }
    });

    updateDisplay();
</script>
{{/fillSection}}
{{#section 'css'}}
<style>
/* ── Hero ─────────────────────────────────── */
.home-hero {
  background: linear-gradient(135deg, #0f0f0f 0%, #1a1a1a 60%, #2a2a2a 100%);
  color: #f1f1f1;
  text-align: center;
  padding: 80px 20px 60px;
  margin-top: -16px;
}
.home-hero h1 { font-size: 2.8rem; font-weight: 900; line-height: 1.2; }
.home-hero h1 span { color: #ff6b35; }
.home-hero p  { font-size: 1.1rem; color: #aaa; margin: 16px 0 28px; }
.hero-cta { display: inline-flex; gap: 12px; flex-wrap: wrap; justify-content: center; }
.btn-hero-primary {
  background: #ff6b35; color: #fff; border: none;
  padding: 12px 32px; border-radius: 30px; font-size: 1rem; font-weight: 700;
  text-decoration: none; transition: background .2s, transform .15s;
}
.btn-hero-primary:hover { background: #e85d24; transform: translateY(-2px); color:#fff; }
.btn-hero-outline {
  background: transparent; color: #f1f1f1; border: 2px solid #555;
  padding: 12px 28px; border-radius: 30px; font-size: 1rem; font-weight: 600;
  text-decoration: none; transition: border-color .2s;
}
.btn-hero-outline:hover { border-color: #ff6b35; color: #ff6b35; }

/* ── Section ──────────────────────────────── */
.food-section { padding: 48px 20px; }
.food-section:nth-child(odd) { background: #fafafa; }
.section-header { text-align: center; margin-bottom: 32px; }
.section-header h2 { font-size: 1.7rem; font-weight: 800; color: var(--text-dark); }
.section-header p  { color: var(--text-muted); margin: 0; }
.section-icon { font-size: 2rem; margin-bottom: 8px; display: block; }

/* ── Food card ─────────────────────────────── */
.food-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px; max-width: 1100px; margin: 0 auto; }
.food-card {
  background: #fff; border-radius: 16px; overflow: hidden;
  box-shadow: 0 2px 12px rgba(0,0,0,.07); transition: transform .2s, box-shadow .2s;
  text-decoration: none; color: inherit; display: flex; flex-direction: column;
}
.food-card:hover { transform: translateY(-4px); box-shadow: 0 8px 28px rgba(0,0,0,.13); color: inherit; }
.food-card-img { width: 100%; height: 160px; object-fit: cover; }
.food-card-body { padding: 14px 16px 16px; flex: 1; display: flex; flex-direction: column; }
.food-card-name { font-weight: 700; font-size: 1rem; color: var(--text-dark); margin-bottom: 4px; }
.food-card-desc { font-size: .82rem; color: var(--text-muted); flex: 1; margin-bottom: 10px;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.food-card-footer { display: flex; align-items: center; justify-content: space-between; }
.food-card-price { font-size: 1rem; font-weight: 800; color: #ff6b35; }
.food-card-badge {
  font-size: .7rem; font-weight: 700; padding: 2px 8px;
  border-radius: 20px; text-transform: uppercase;
}
.badge-new      { background: #E8F5E9; color: #2e7d32; }
.badge-hot      { background: #FFF3E0; color: #e65100; }
.badge-best     { background: #fce4ec; color: #c62828; }

/* ── Empty state ──────────────────────────── */
.empty-section { text-align: center; padding: 32px; color: var(--text-muted); }
</style>
{{/section}}

<!-- Hero Banner -->
<div class="home-hero col-12 px-0">
  <span style="font-size:3.5rem;">🍽️</span>
  <h1>Đặt món ngon<br><span>giao tận nơi</span></h1>
  <p>Thực đơn đa dạng · Giao nhanh · Giá tốt</p>
  <div class="hero-cta">
    <a href="/menu" class="btn-hero-primary"><i class="bi bi-grid me-2"></i>Xem thực đơn</a>
    {{#if isAuthenticated}}
    <a href="/order" class="btn-hero-outline"><i class="bi bi-receipt me-2"></i>Đơn hàng của tôi</a>
    {{else}}
    <a href="/account/signup" class="btn-hero-outline"><i class="bi bi-person-plus me-2"></i>Đăng ký ngay</a>
    {{/if}}
  </div>
</div>

<!-- Section: Món nổi bật -->
<div class="food-section col-12 px-0">
  <div class="section-header">
    <span class="section-icon">⭐</span>
    <h2>Món nổi bật</h2>
    <p>Những món được yêu thích nhất</p>
  </div>
  {{#if (isEmpty featured)}}
  <div class="empty-section"><i class="bi bi-emoji-smile fs-2"></i><p class="mt-2">Sắp có món ngon!</p></div>
  {{else}}
  <div class="food-grid">
    {{#each featured}}
    <a href="/menu" class="food-card">
      <img class="food-card-img"
        src="{{#if imageUrl}}{{imageUrl}}{{else}}/public/imgs/no_image.jpg{{/if}}"
        onerror="this.src='/public/imgs/no_image.jpg'" alt="{{name}}">
      <div class="food-card-body">
        <div class="food-card-name">{{name}}</div>
        <div class="food-card-desc">{{#if description}}{{description}}{{else}}Món ăn ngon, hấp dẫn{{/if}}</div>
        <div class="food-card-footer">
          <span class="food-card-price">{{formatCurrency basePrice}}</span>
          <span class="food-card-badge badge-hot">⭐ Nổi bật</span>
        </div>
      </div>
    </a>
    {{/each}}
  </div>
  {{/if}}
</div>

<!-- Section: Bán chạy nhất -->

<style>
  body { background: #0f0f0f; color: #f1f1f1; font-family: 'Segoe UI', sans-serif; }

  .menu-hero {
    text-align: center;
    padding: 48px 20px 24px;
  }
  .menu-hero h1 { font-size: 2.2rem; font-weight: 700; color: #fff; margin-bottom: 8px; }
  .menu-hero p  { color: #888; font-size: 1rem; }

  .filter-bar {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
    padding: 16px 20px;
  }
  .filter-btn {
    padding: 8px 20px;
    border-radius: 999px;
    border: 1px solid #333;
    background: #1a1a1a;
    color: #aaa;
    cursor: pointer;
    font-size: 0.9rem;
    transition: all 0.2s;
  }
  .filter-btn:hover, .filter-btn.active {
    background: #e85d24;
    border-color: #e85d24;
    color: #fff;
  }

  .menu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 20px;
    padding: 20px 40px 60px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .food-card {
    background: #1a1a1a;
    border: 1px solid #2a2a2a;
    border-radius: 16px;
    overflow: hidden;
    transition: transform 0.2s, border-color 0.2s;
    cursor: pointer;
  }
  .food-card:hover {
    transform: translateY(-4px);
    border-color: #e85d24;
  }
  .food-card-img {
    width: 100%;
    height: 150px;
    background: #2a2a2a;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3.5rem;
  }
  .food-card-body { padding: 14px; }
  .food-card-type {
    font-size: 0.75rem;
    color: #e85d24;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 4px;
  }
  .food-card-name {
    font-size: 1rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 8px;
  }
  .food-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .food-card-price { color: #e85d24; font-weight: 700; font-size: 1rem; }
  .btn-add {
    background: #e85d24;
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 6px 14px;
    font-size: 0.85rem;
    cursor: pointer;
  }
  .btn-add:hover { background: #cf4e1a; }
  .no-result { text-align: center; color: #555; padding: 40px; display: none; }
</style>

<div class="menu-hero">
  <h1>🍔 Thực Đơn</h1>
  <p>Chọn món yêu thích của bạn</p>
</div>

<div class="filter-bar">
  <button class="filter-btn active" onclick="filterMenu(this, 'all')">Tất cả</button>
  <button class="filter-btn" onclick="filterMenu(this, 'pizza')">🍕 Pizza</button>
  <button class="filter-btn" onclick="filterMenu(this, 'burger')">🍔 Burger</button>
  <button class="filter-btn" onclick="filterMenu(this, 'pasta')">🍝 Pasta</button>
  <button class="filter-btn" onclick="filterMenu(this, 'salad')">🥗 Salad</button>
  <button class="filter-btn" onclick="filterMenu(this, 'soup')">🍲 Súp</button>
  <button class="filter-btn" onclick="filterMenu(this, 'dessert')">🍰 Tráng miệng</button>
  <button class="filter-btn" onclick="filterMenu(this, 'drink')">🥤 Đồ uống</button>
</div>

<div class="menu-grid" id="menuGrid">
  {{#each foods}}
  <div class="food-card" data-type="{{type}}">
    <div class="food-card-img">{{typeEmoji type}}</div>
    <div class="food-card-body">
      <div class="food-card-type">{{type}}</div>
      <div class="food-card-name">{{name}}</div>
      <div class="food-card-footer">
        <span class="food-card-price">{{price}}k</span>
        <button class="btn-add">+ Thêm</button>
      </div>
    </div>
  </div>
  {{/each}}
</div>

<p class="no-result" id="noResult">Không có món nào 😕</p>

<script>
  function filterMenu(btn, type) {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    const cards = document.querySelectorAll('.food-card');
    let count = 0;
    cards.forEach(card => {
      const show = type === 'all' || card.dataset.type === type;
      card.style.display = show ? 'block' : 'none';
      if (show) count++;
    });
    document.getElementById('noResult').style.display = count === 0 ? 'block' : 'none';
  }
</script>
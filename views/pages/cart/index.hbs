{{#fillSection "css"}}
<style>
  .cart-wrap {
    max-width: 900px;
    margin: 0 auto;
    padding: 32px 20px 60px;
  }

  .cart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
  }

  .cart-header h1 {
    font-size: 1.7rem;
    font-weight: 800;
  }

  /* ── Empty state ──────────────────────────────────────── */
  .cart-empty {
    text-align: center;
    padding: 64px 20px;
    color: var(--text-muted);
  }

  .cart-empty i {
    font-size: 3.5rem;
    display: block;
    margin-bottom: 16px;
    color: var(--green-soft);
  }

  .cart-empty p {
    font-size: 1.1rem;
    margin-bottom: 20px;
  }

  /* ── Layout ───────────────────────────────────────────── */
  .cart-layout {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 24px;
    align-items: start;
  }

  @media (max-width: 720px) {
    .cart-layout {
      grid-template-columns: 1fr;
    }
  }

  /* ── Cart item ────────────────────────────────────────── */
  .cart-item-card {
    background: #fff;
    border: 2px solid #f0f0f0;
    border-radius: 14px;
    padding: 16px 18px;
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 12px;
    transition: border-color .2s;
  }

  .cart-item-card:hover {
    border-color: var(--green-soft);
  }

  .item-emoji {
    font-size: 2.4rem;
    flex-shrink: 0;
  }

  .item-info {
    flex: 1;
  }

  .item-name {
    font-weight: 700;
    font-size: .98rem;
    color: var(--text-dark);
    margin-bottom: 3px;
  }

  .item-toppings {
    font-size: .78rem;
    color: var(--text-muted);
    margin-bottom: 6px;
  }

  .item-unit-price {
    font-size: .8rem;
    color: var(--text-muted);
  }

  .item-controls {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 8px;
    flex-shrink: 0;
  }

  .item-subtotal {
    font-weight: 800;
    font-size: 1rem;
    color: var(--green-soft);
  }

  .qty-row-inline {
    display: flex;
    align-items: center;
    border: 2px solid #e8e8e8;
    border-radius: 10px;
    overflow: hidden;
  }

  .qb {
    width: 34px;
    height: 34px;
    border: none;
    background: #f5f5f5;
    font-size: 1.1rem;
    cursor: pointer;
    transition: background .15s;
  }

  .qb:hover {
    background: var(--green-light);
  }

  .qv {
    width: 38px;
    text-align: center;
    font-weight: 800;
    font-size: .9rem;
    color: var(--text-dark);
  }

  .btn-remove {
    border: none;
    background: none;
    color: #ccc;
    cursor: pointer;
    font-size: .8rem;
    transition: color .15s;
    padding: 0;
  }

  .btn-remove:hover {
    color: #e53935;
  }

  /* ── Summary box ──────────────────────────────────────── */
  .summary-box {
    background: #fff;
    border: 2px solid #f0f0f0;
    border-radius: 16px;
    padding: 24px;
    position: sticky;
    top: 80px;
  }

  .summary-box h3 {
    font-size: 1.1rem;
    font-weight: 800;
    margin-bottom: 18px;
  }

  .summary-row {
    display: flex;
    justify-content: space-between;
    font-size: .9rem;
    padding: 6px 0;
    border-bottom: 1px solid #f5f5f5;
    color: var(--text-muted);
  }

  .summary-row:last-of-type {
    border-bottom: none;
  }

  .summary-total {
    display: flex;
    justify-content: space-between;
    font-size: 1.15rem;
    font-weight: 800;
    padding: 14px 0 18px;
    color: var(--text-dark);
    border-top: 2px solid var(--green-soft);
    margin-top: 10px;
  }

  .summary-total .amt {
    color: var(--green-soft);
  }

  .btn-checkout {
    width: 100%;
    padding: 13px;
    border-radius: 12px;
    border: none;
    background: var(--green-soft);
    color: #fff;
    font-size: 1rem;
    font-weight: 800;
    cursor: pointer;
    transition: background .15s;
    margin-bottom: 10px;
  }

  .btn-checkout:hover {
    background: #388e3c;
  }

  .btn-checkout:disabled {
    opacity: .55;
    cursor: not-allowed;
  }

  .btn-clear-cart {
    width: 100%;
    padding: 8px;
    border-radius: 10px;
    border: 2px solid #e8e8e8;
    background: transparent;
    color: var(--text-muted);
    font-size: .85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all .15s;
  }

  .btn-clear-cart:hover {
    border-color: #e53935;
    color: #e53935;
  }

  /* ── Login notice ─────────────────────────────────────── */
  .login-notice {
    background: #fff8e1;
    border: 2px solid #ffc107;
    border-radius: 12px;
    padding: 12px 16px;
    font-size: .88rem;
    margin-bottom: 14px;
    color: #795548;
  }

  .login-notice a {
    color: var(--green-soft);
    font-weight: 700;
  }
</style>
{{/fillSection}}

<div class="cart-wrap">
  <div class="cart-header">
    <h1>🛒 Giỏ hàng</h1>
    <a href="/menu" class="btn btn-outline-success">
      <i class="bi bi-arrow-left me-1"></i>Tiếp tục mua
    </a>
  </div>

  {{#if isEmpty}}
  <!-- Empty state -->
  <div class="cart-empty">
    <i class="bi bi-cart-x"></i>
    <p>Giỏ hàng của bạn đang trống.</p>
  </div>

  {{else}}
  <!-- Cart with items -->
  <div class="cart-layout">

    <!-- Item list -->
    <div id="cartItemList">
      {{#each cart.items}}
      <div class="cart-item-card" data-id="{{cartItemId}}">
        <div class="item-emoji">{{typeEmoji type}}</div>
        <div class="item-info">
          <div class="item-name">{{name}}</div>
          {{#if toppings.length}}
          <div class="item-toppings">
            <i class="bi bi-plus-circle-fill" style="color:var(--green-soft)"></i>
            {{#each toppings}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}
          </div>
          {{/if}}
          <div class="item-unit-price">{{formatNumber unitPrice}}đ / món</div>
        </div>
        <div class="item-controls">
          <div class="item-subtotal" id="sub-{{cartItemId}}">{{formatNumber subtotal}}đ</div>
          <div class="qty-row-inline">
            <button class="qb" onclick="updateQty('{{cartItemId}}', -1)">−</button>
            <span class="qv" id="qty-{{cartItemId}}">{{quantity}}</span>
            <button class="qb" onclick="updateQty('{{cartItemId}}', 1)">+</button>
          </div>
          <button class="btn-remove" onclick="removeItem('{{cartItemId}}')">
            <i class="bi bi-trash3 me-1"></i>Xoá
          </button>
        </div>
      </div>
      {{/each}}
    </div>

    <!-- Summary -->
    <div class="summary-box">
      <h3>Tóm tắt đơn</h3>

      {{#unless isAuthenticated}}
      <div class="login-notice">
        <i class="bi bi-info-circle me-1"></i>
        <a href="/account/signin">Đăng nhập</a> để đặt hàng và theo dõi đơn.
      </div>
      {{/unless}}

      <div class="summary-row">
        <span>Số món</span>
        <span id="summaryQty">{{cart.totalQty}}</span>
      </div>
      <div class="summary-row">
        <span>Tạm tính</span>
        <span id="summaryAmt">{{formatNumber cart.totalAmount}}đ</span>
      </div>
      <div class="summary-row">
        <span>Phí giao hàng</span>
        <span>Miễn phí</span>
      </div>

      <div class="summary-total">
        <span>Tổng cộng</span>
        <span class="amt" id="summaryTotal">{{formatNumber cart.totalAmount}}đ</span>
      </div>

      {{#if isAuthenticated}}
      <form action="/cart/checkout" method="POST">
        <button type="submit" class="btn-checkout" id="checkoutBtn">
          <i class="bi bi-bag-check me-1"></i>Đặt hàng & thanh toán
        </button>
      </form>
      {{else}}
      <a href="/account/signin?ret=/cart" class="btn-checkout d-block text-center text-decoration-none">
        <i class="bi bi-box-arrow-in-right me-1"></i>Đăng nhập để đặt hàng
      </a>
      {{/if}}

      <button class="btn-clear-cart" onclick="clearCart()">
        <i class="bi bi-x-circle me-1"></i>Xoá giỏ hàng
      </button>
    </div>
  </div>
  {{/if}}
</div>

<div id="cart-data" data-qty="{{cart.totalQty}}" data-amount="{{cart.totalAmount}}" style="display:none;">{{{json
  cart.items}}}</div>

{{#fillSection "js"}}
<script>
  const fmt = n => new Intl.NumberFormat('vi-VN').format(n);

  // Keep a local snapshot so we can update totals without a page reload
  const _cd = document.getElementById('cart-data');
  let localCart = {
    items: JSON.parse(_cd.textContent || '[]'),
    totalQty: Number(_cd.getAttribute('data-qty')) || 0,
    totalAmount: Number(_cd.getAttribute('data-amount')) || 0,
  };

  function refreshSummary(cart) {
    localCart = cart;
    const qtyEl = document.getElementById('summaryQty');
    const amtEl = document.getElementById('summaryAmt');
    const totEl = document.getElementById('summaryTotal');
    const badge = document.getElementById('cartCountBadge');
    if (qtyEl) qtyEl.textContent = cart.totalQty;
    if (amtEl) amtEl.textContent = fmt(cart.totalAmount) + 'đ';
    if (totEl) totEl.textContent = fmt(cart.totalAmount) + 'đ';
    if (badge) badge.textContent = cart.totalQty;
  }

  async function updateQty(cartItemId, delta) {
    const qtyEl = document.getElementById('qty-' + cartItemId);
    const subEl = document.getElementById('sub-' + cartItemId);
    const item = localCart.items.find(i => i.cartItemId === cartItemId);
    if (!item) return;

    const newQty = Math.max(0, item.quantity + delta);

    try {
      const res = await fetch('/cart/update', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ cartItemId, quantity: newQty }),
      });
      const data = await res.json();
      if (!data.success) return;

      if (newQty === 0) {
        // Remove card from DOM
        document.querySelector(`.cart-item-card[data-id="${cartItemId}"]`)?.remove();
        if (!data.cart.items.length) location.reload(); // show empty state
      } else {
        const updated = data.cart.items.find(i => i.cartItemId === cartItemId);
        if (updated) {
          if (qtyEl) qtyEl.textContent = updated.quantity;
          if (subEl) subEl.textContent = fmt(updated.subtotal) + 'đ';
          item.quantity = updated.quantity;
          item.subtotal = updated.subtotal;
        }
      }
      refreshSummary(data.cart);
    } catch (e) { console.error(e); }
  }

  async function removeItem(cartItemId) {
    try {
      const res = await fetch('/cart/remove/' + cartItemId, { method: 'DELETE' });
      const data = await res.json();
      if (!data.success) return;
      document.querySelector(`.cart-item-card[data-id="${cartItemId}"]`)?.remove();
      localCart.items = localCart.items.filter(i => i.cartItemId !== cartItemId);
      if (!data.cart.items.length) { location.reload(); return; }
      refreshSummary(data.cart);
    } catch (e) { console.error(e); }
  }

  async function clearCart() {
    if (!confirm('Xoá toàn bộ giỏ hàng?')) return;
    try {
      await fetch('/cart/clear', { method: 'DELETE' });
      location.reload();
    } catch (e) {
      location.reload();
    }
  }
</script>
{{/fillSection}}